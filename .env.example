# Copy this file to ".env" and fill in your real values.
# The .env file is private — it is never committed or shared.

# --- Claude (the brain) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Canvas (UW) ---
CANVAS_BASE_URL=https://canvas.uw.edu/api/v1
CANVAS_TOKEN=

# --- Twilio (texting) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=        # your Twilio phone number, e.g. +12065550123

# --- You ---
MY_PHONE_NUMBER=           # your personal phone, the only number allowed, e.g. +12065559876

# --- Web address of this app (for study-page links) ---
# When running locally with a tunnel, use the tunnel URL (e.g. https://abc123.ngrok.io).
# When deployed, use your host URL (e.g. https://yourapp.up.railway.app).
PUBLIC_BASE_URL=http://localhost:8000

# --- Where local data files live (conversation history, study pages, reminders) ---
DATA_DIR=./data
